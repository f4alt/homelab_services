# Copy this file to .env or export these values before running Docker Compose.

# Container defaults. For local non-container runs, point TODO_DIRECTORY
# at your actual todo files.
TODO_DIRECTORY=/data/todo_files
SYNC_STATE_FILE=/data/todo_files/.todo-sync-state.json
SYNC_INTERVAL_SECONDS=60

# Docker Compose host-published ports. Container ports stay fixed.
API_HOST_PORT=5000
RADICALE_HOST_PORT=5232

# Host paths mounted into the Radicale container.
TODO_FILES_HOST_PATH=../todo_files
RADICALE_CONFIG_HOST_PATH=./radicale/config
RADICALE_USERS_HOST_PATH=./radicale/users
RADICALE_CERT_HOST_PATH=./radicale/generated-certs

CALDAV_URL=https://radicale:5232/
CALDAV_USERNAME=todo
CALDAV_PASSWORD=todo
CALDAV_VERIFY_SSL=false
CALDAV_COLLECTION_PREFIX=

RADICALE_CERT_DAYS=825
RADICALE_CERT_RENEW_BEFORE_DAYS=30
RADICALE_CERT_CHECK_INTERVAL_SECONDS=172800
RADICALE_CERT_COMMON_NAME=radicale.local
# Optional comma-separated SANs. Use this if auto-detection picks the wrong LAN IP.
# RADICALE_CERT_EXTRA_SANS=IP:192.168.1.25,DNS:todo.local

API_HOST=0.0.0.0
# Local non-Docker API port. Compose uses API_HOST_PORT for host publishing.
API_PORT=5000
API_ENABLE_CORS=true
