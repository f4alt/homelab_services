# Dashboard host port exposed by Nginx.
DASHBOARD_HTTP_PORT=8080

# Gateway upstream timeout for dependency calls, in milliseconds.
GATEWAY_UPSTREAM_TIMEOUT_MS=5000

# Todo server base URL.
TODO_API_BASE_URL=http://host.docker.internal:5000

# Status probe timeout, target count, concurrency, and allowed host patterns.
STATUS_PROBE_TIMEOUT_MS=5000
STATUS_PROBE_MAX_TARGETS=100
STATUS_PROBE_CONCURRENCY=10
STATUS_PROBE_ALLOWED_HOSTS=localhost

# Default ping target used by Netstats when no target is requested.
NETSTATS_PING_TARGET=8.8.8.8
